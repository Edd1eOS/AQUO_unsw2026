{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "entrypoints/**/*",
    "components/**/*",
    "lib/**/*",
    "hooks/**/*",
    "types/**/*",
    "src/**/*",
    ".wxt/types/**/*"
  ]
}
